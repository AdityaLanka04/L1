# Copy this file to .env and fill in your values
# cp .env.example .env

# ==================== DATABASE ====================
# Option 1: SQLite (easiest for local dev)
DATABASE_URL=sqlite:///./brainwave.db

# Option 2: PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Supabase pooler: use port 6543 or set SUPABASE_POOLER=true to rewrite 5432 -> 6543.
SUPABASE_POOLER=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=10
DB_APPLICATION_NAME=brainwave_api

# ==================== SECURITY ====================
SECRET_KEY=generate-a-random-secret-key-here
ALGORITHM=HS256

# ==================== AI APIs (at least one required) ====================
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_KEY=your-gemini-api-key
# Optional: comma-separated key pool. The backend rotates when a key reaches quota.
# GOOGLE_GENERATIVE_AI_KEYS=gemini-key-1,gemini-key-2,gemini-key-3

# Get from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
# Optional: comma-separated key pool. The backend rotates when a key reaches quota.
# GROQ_API_KEYS=groq-key-1,groq-key-2,groq-key-3

# Daily budget per key tracked by the backend. Provider-specific values override this.
AI_KEY_DAILY_TOKEN_LIMIT=10000
# GEMINI_DAILY_TOKEN_LIMIT=10000
# GROQ_DAILY_TOKEN_LIMIT=10000

# OpenAI-compatible high-school/context provider pool, if enabled.
# HS_CONTEXT_API_KEYS=key-1,key-2
# HS_CONTEXT_DAILY_TOKEN_LIMIT=10000

# ==================== GOOGLE OAUTH ====================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id

# ==================== STORAGE ====================
STORAGE_TYPE=local
STORE_ORIGINAL_FILES=false
UPLOAD_DIR=uploads
# For production redundancy, use S3 for uploads/files:
# STORAGE_TYPE=s3
# AWS_S3_BUCKET=your-cerbyl-uploads-bucket
# AWS_REGION=us-east-2
# Optional when using IAM roles on EC2; required only for local/dev credentials:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional public CDN/CloudFront base URL. If omitted, backend returns presigned S3 URLs.
# AWS_S3_PUBLIC_URL=
# AWS_S3_PRESIGNED_URL_TTL=900

# ==================== CACHING SYSTEM ====================
# Redis Configuration (optional - for distributed caching)
# If not set, uses in-memory cache only
# REDIS_URL=redis://localhost:6379/0
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ==================== AI JOB QUEUE ====================
# Production AI requests should be queued and processed by dedicated worker containers.
AI_JOB_QUEUE_NAME=bw:ai_jobs:default
AI_JOB_RETRY_QUEUE_NAME=bw:ai_jobs:default:retry
AI_JOB_DEAD_LETTER_QUEUE_NAME=bw:ai_jobs:default:dead
AI_MAX_ACTIVE_JOBS_PER_USER=4
AI_JOB_MAX_ATTEMPTS=3
AI_JOB_RETRY_BASE_DELAY_SECONDS=10
AI_JOB_RATE_LIMIT_RETRY_DELAY_SECONDS=60
AI_JOB_RETRY_MAX_DELAY_SECONDS=300
AI_JOB_CHAT_TIMEOUT_SECONDS=180
AI_JOB_ROUTE_TIMEOUT_SECONDS=240
AI_JOB_FILE_TIMEOUT_SECONDS=420
AI_JOB_MEDIA_TIMEOUT_SECONDS=600
AI_JOB_ADMIN_EMAILS=
# Comma-separated whitelist for existing AI-heavy API endpoints that may run inside AI workers.
# Keep this narrow; do not include auth/account endpoints.
# AI_JOB_ALLOWED_LEGACY_PATHS=/api/agents/searchhub,/api/generate_flashcards,/api/create_knowledge_roadmap

# RedisVL semantic cache for repeated/similar AI prompts.
# Requires Redis Stack/Redis Cloud with vector search support plus redisvl.
AI_SEMANTIC_CACHE_ENABLED=false
AI_SEMANTIC_CACHE_SCOPE=user
AI_SEMANTIC_CACHE_INDEX=brainwave_ai_semantic_cache
AI_SEMANTIC_CACHE_DISTANCE_THRESHOLD=0.12
AI_SEMANTIC_CACHE_TTL_SECONDS=86400
AI_SEMANTIC_CACHE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
REACT_APP_USE_AI_JOB_QUEUE=false

# Enable/disable Redis cache (default: true if REDIS_URL is set)
ENABLE_REDIS_CACHE=true

# Cache TTL Settings (in seconds)
CACHE_TTL_SECONDS=3600          # Default TTL for general cache (1 hour)
RAG_CACHE_TTL=1800              # RAG query cache TTL (30 minutes)
DB_CACHE_TTL=300                # Database query cache TTL (5 minutes)
EMBEDDING_CACHE_TTL=7200        # Embedding cache TTL (2 hours)
API_CACHE_TTL=60                # API response cache TTL (1 minute)

# Cache Size Limits (number of entries)
MAX_MEMORY_CACHE_SIZE=10000     # Maximum entries in memory cache
AI_CACHE_SIZE=1000              # AI response cache size
RAG_CACHE_SIZE=500              # RAG query cache size
DB_CACHE_SIZE=2000              # Database query cache size
EMBEDDING_CACHE_SIZE=5000       # Embedding cache size
API_CACHE_SIZE=1000             # API response cache size

# ==================== FIREBASE (React frontend) ====================
# Get from: Firebase Console > Project Settings > Your Apps > Web app
REACT_APP_FIREBASE_API_KEY=your-firebase-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id
REACT_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ==================== ADMIN ====================
# Backend admin-only API usage dashboard
API_USAGE_ADMIN_EMAILS=aditya.s.lanka@gmail.com,rithvikkumar35@gmail.com
