<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.brainwaveai.sqlite-backup</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/adityalanka/BrainwaveAI &amp;&amp; mkdir -p backend/backups/sqlite/logs &amp;&amp; /usr/bin/python3 scripts/sqlite_backup.py backup</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>18</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/adityalanka/BrainwaveAI/backend/backups/sqlite/logs/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/adityalanka/BrainwaveAI/backend/backups/sqlite/logs/launchd.err.log</string>
</dict>
</plist>
