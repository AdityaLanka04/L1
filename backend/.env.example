# Copy this file to .env and fill in your values
# cp .env.example .env

# ==================== DATABASE ====================
# Option 1: SQLite (easiest for local dev)
DATABASE_URL=sqlite:///./brainwave.db

# Option 2: PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ==================== SECURITY ====================
SECRET_KEY=generate-a-random-secret-key-here
ALGORITHM=HS256

# ==================== AI APIs (at least one required) ====================
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_KEY=your-gemini-api-key
# Optional: comma-separated key pool. The backend rotates when a key reaches quota.
# GOOGLE_GENERATIVE_AI_KEYS=gemini-key-1,gemini-key-2,gemini-key-3

# Get from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
# Optional: comma-separated key pool. The backend rotates when a key reaches quota.
# GROQ_API_KEYS=groq-key-1,groq-key-2,groq-key-3

# Daily budget per key tracked by the backend. Provider-specific values override this.
AI_KEY_DAILY_TOKEN_LIMIT=10000
# GEMINI_DAILY_TOKEN_LIMIT=10000
# GROQ_DAILY_TOKEN_LIMIT=10000

# OpenAI-compatible high-school/context provider pool, if enabled.
# HS_CONTEXT_API_KEYS=key-1,key-2
# HS_CONTEXT_DAILY_TOKEN_LIMIT=10000

# ==================== GOOGLE OAUTH ====================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id

# ==================== STORAGE ====================
STORAGE_TYPE=local
STORE_ORIGINAL_FILES=false
UPLOAD_DIR=uploads

# ==================== ADMIN ====================
# Comma-separated list of admin emails (required for admin analytics endpoints)
ADMIN_EMAILS=admin@example.com
# Comma-separated list allowed to see API key usage.
API_USAGE_ADMIN_EMAILS=aditya.s.lanka@gmail.com,rithvikkumar35@gmail.com

# ==================== DEPLOYMENT ====================
# Set to "production" to enable production-only safeguards (PostgreSQL required, CORS locked down)
ENVIRONMENT=development

# Comma-separated allowed origins (production only — ignored in development)
ALLOWED_ORIGINS=https://yourdomain.com

# ==================== FIREBASE (optional) ====================
# Required only if using Firebase Authentication
# FIREBASE_PROJECT_ID=your-firebase-project-id

# ==================== OPTIONAL ====================
# Inactivity reminders (comma-separated hours)
# Example: 24,72,168 for 1 day, 3 days, 7 days
INACTIVITY_NOTIFICATION_HOURS=72,168

# YouTube Data API v3 (optional - for enhanced video metadata)
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your-youtube-api-key

# yt-dlp cloud hardening (optional, useful for Azure/AWS/GCP)
# If YouTube blocks server IP with sign-in/bot challenge, provide one of:
# 1) Path to Netscape cookie file mounted in container
# YTDLP_COOKIES_FILE=/app/secrets/youtube_cookies.txt
# 2) Base64-encoded Netscape cookie file content
# YTDLP_COOKIES_B64=
#
# Optional network settings
# YTDLP_PROXY_URL=
# YTDLP_USER_AGENT=
# YTDLP_EXTRACTOR_ARGS=youtube:player_client=android,web,ios

# RapidAPI YouTube Transcript (REQUIRED for YouTube features in production)
# Get from: https://rapidapi.com/solid-api-solid-api-default/api/youtube-transcriptor
# Free tier: 500 requests/month, Basic: $10/month for 10,000 requests
RAPIDAPI_KEY=your-rapidapi-key

# ASSEMBLYAI_API_KEY=your-assemblyai-key
# HUGGINGFACE_API_KEY=your-huggingface-key
